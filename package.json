{
  "name": "mu-code",
  "version": "1.0.0",
  "description": "AI-powered coding assistant with beautiful UI - inspired by claw-code",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "node server/proxy.js",
